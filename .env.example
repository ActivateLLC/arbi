# ========================================
# ARBI Platform Environment Variables
# ========================================

# ----------------------------------------
# API / Backend Configuration (REQUIRED)
# ----------------------------------------

# Database - Railway PostgreSQL (REQUIRED for production)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:PORT/railway?sslmode=require

# Alternative: Individual database variables (use DATABASE_URL instead if possible)
# DB_HOST=your-postgres-host
# DB_PORT=5432
# DB_NAME=railway
# DB_USER=postgres
# DB_PASSWORD=your-database-password
# DB_SSL=true

# Server Configuration
NODE_ENV=development
PORT=3000
API_URL=https://your-api.railway.app

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://your-dashboard.vercel.app,https://your-landing.vercel.app

# ----------------------------------------
# Payment Processing (REQUIRED)
# ----------------------------------------

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ----------------------------------------
# Cloud Storage (REQUIRED)
# ----------------------------------------

# Cloudinary - For product images and video ads
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ----------------------------------------
# AI & APIs (OPTIONAL)
# ----------------------------------------

# OpenAI - For content generation
OPENAI_API_KEY=sk-your-openai-api-key

# ElevenLabs - For voice generation
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Rainforest API - For product data
RAINFOREST_API_KEY=your-rainforest-api-key

# Google Gemini - For AI features (dashboard)
GEMINI_API_KEY=your-gemini-api-key

# ----------------------------------------
# Advertising & Marketing (OPTIONAL)
# ----------------------------------------

# Google Ads
GOOGLE_ADS_CLIENT_ID=your-google-ads-client-id
GOOGLE_ADS_CLIENT_SECRET=your-google-ads-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token
GOOGLE_ADS_REFRESH_TOKEN=your-google-ads-refresh-token
GOOGLE_ADS_CUSTOMER_ID=your-google-ads-customer-id

# Meta/Facebook Ads
META_ACCESS_TOKEN=your-meta-access-token
META_AD_ACCOUNT_ID=your-meta-ad-account-id

# TikTok Ads
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token
TIKTOK_AD_ACCOUNT_ID=your-tiktok-ad-account-id

# ----------------------------------------
# Product Sourcing (OPTIONAL)
# ----------------------------------------

# 1688/Taobao/AliExpress
ALIBABA_APP_KEY=your-alibaba-app-key
ALIBABA_APP_SECRET=your-alibaba-app-secret

# CJ Dropshipping
CJ_ACCESS_TOKEN=your-cj-access-token

# ----------------------------------------
# Frontend Environment Variables
# ----------------------------------------

# Dashboard (apps/dashboard)
VITE_API_URL=https://your-api.railway.app
VITE_GEMINI_API_KEY=your-gemini-api-key

# Landing Page (apps/landing)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ----------------------------------------
# Development Only
# ----------------------------------------

# Set to 'true' to enable debug logging
DEBUG=false

# ----------------------------------------
# Deployment Notes
# ----------------------------------------

# Railway (Backend API):
# - Set DATABASE_URL, STRIPE_SECRET_KEY, CLOUDINARY_* as minimum
# - Add ALLOWED_ORIGINS with your Vercel deployment URLs
# - Set NODE_ENV=production
#
# Vercel (Frontend):
# - Dashboard: Set VITE_API_URL to your Railway API URL
# - Landing: Set VITE_API_URL and VITE_SUPABASE_* keys
#
# Required for production:
# ✅ DATABASE_URL
# ✅ STRIPE_SECRET_KEY
# ✅ CLOUDINARY_CLOUD_NAME
# ✅ CLOUDINARY_API_KEY
# ✅ CLOUDINARY_API_SECRET
# ✅ API_URL (for internal API calls)
# ✅ ALLOWED_ORIGINS (CORS security)
