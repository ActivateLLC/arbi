{
  "name": "@arbi/api",
  "version": "0.1.0",
  "private": true,
  "description": "Arbi API server",
  "main": "dist/index.js",
  "scripts": {
    "build": "prisma generate && tsup src/index.ts --format cjs",
    "dev": "tsx watch src/index.ts",
    "start": "prisma db push --skip-generate --accept-data-loss && tsx prisma/seed.ts && node dist/index.js",
    "start:prod": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "clean": "rm -rf dist node_modules",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@arbi/ai-engine": "workspace:*",
    "@arbi/arbitrage-engine": "workspace:*",
    "@arbi/data": "workspace:*",
    "@arbi/transaction": "workspace:*",
    "@arbi/voice-interface": "workspace:*",
    "@arbi/web-automation": "workspace:*",
    "@browserbasehq/stagehand": "^1.7.2",
    "@imgly/background-removal-node": "^1.4.5",
    "@prisma/client": "^5.22.0",
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "amazon-buddy": "^2.2.45",
    "axios": "^1.6.5",
    "cheerio": "^1.1.2",
    "cloudinary": "^2.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "facebook-nodejs-business-sdk": "^24.0.1",
    "google-ads-api": "^21.0.1",
    "googleapis": "^167.0.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.12",
    "playwright": "^1.40.1",
    "prisma": "^5.22.0",
    "remotion": "^4.0.0",
    "stripe": "^20.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@arbi/eslint-config": "workspace:*",
    "@arbi/tsconfig": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.5",
    "@types/nodemailer": "^6.4.14",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
